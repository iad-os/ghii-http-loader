{
  "name": "@ghii/http-loader",
  "version": "1.0.0",
  "description": "A Funny http loader for ghii configuration manager ",
  "maintainers": [
    {
      "name": "Daniele Fiungo",
      "email": "daniele.fiungo@iad2.it"
    },
    {
      "name": "Irene La Bollita",
      "email": "irene.labollita@iad2.it"
    }
  ],
  "author": "Daniele Fiungo <daniele.fiungo@iad2.it>",
  "keywords": [
    "node",
    "config"
  ],
  "main": "dist/lib/http-loader.js",
  "types": "dist/types/http-loader.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types/http-loader.d.ts",
      "import": "./dist/lib/http-loader.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iad-os/ghii-http-loader.git"
  },
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "lint": "eslint . --ext .ts,.tsx",
    "prebuild": "rimraf dist",
    "build": "tsc",
    "try-loader": "npm run build --silent && node scripts/try-loader.mjs",
    "start": "rollup -c rollup.config.ts -w",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --watch",
    "test:prod": "npm run lint && npm run test -- --no-cache",
    "deploy-docs": "ts-node tools/gh-pages-publish"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "transform": {
      ".(ts|tsx)": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    },
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "testEnvironment": "node",
    "testRegex": "(/__tests__/.*|\\.(test|spec))\\.(ts|tsx)$",
    "moduleFileExtensions": [
      "ts",
      "js"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "src/__test__/"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 90,
        "functions": 95,
        "lines": 95,
        "statements": 95
      }
    },
    "collectCoverageFrom": [
      "src/*.{js,ts}"
    ]
  },
  "devDependencies": {
    "@ghii/ghii": "^1.1.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^18.19.130",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.10.2",
    "eslint-plugin-prettier": "^4.2.5",
    "jest": "^29.7.0",
    "jest-config": "^29.7.0",
    "prettier": "^2.8.8",
    "rimraf": "^4.4.1",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3"
  }
}
